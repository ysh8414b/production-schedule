        ax.text(meat_cols[1] + 0.1, y + 0.06, str(row["상품명"]), fontsize=7.5, va="center", color="#212529")
        ax.text(meat_cols[2] + 0.1, y + 0.06, str(row["원산지"]), fontsize=7.5, va="center", color="#495057")
        ax.text(meat_cols[3] + 0.9, y + 0.06, f"{kg_val:,.1f}", fontsize=7.5, va="center", ha="right", color="#212529")
        ax.text(meat_cols[4] + 0.5, y + 0.06, f"{box_val:,}", fontsize=7.5, va="center", ha="right", color="#212529")

    # 원육 합계
    if not meat_agg.empty:
        y_total_m = y_top - 0.42 - len(meat_agg) * row_h - 0.05
        ax.add_patch(plt.Rectangle((8.7, y_total_m - 0.08), 9.2, row_h, facecolor="#F3E5F5", edgecolor="none"))
        ax.text(meat_cols[1] + 0.1, y_total_m + 0.06, f"합계 ({len(meat_agg)}종)",
                fontsize=8, fontweight="bold", va="center")
        ax.text(meat_cols[3] + 0.9, y_total_m + 0.06, f"{meat_agg['잔량Kg'].sum():,.1f}",
                fontsize=8, fontweight="bold", va="center", ha="right", color="#7B1FA2")
        ax.text(meat_cols[4] + 0.5, y_total_m + 0.06, f"{meat_agg['잔량Box'].sum():,}",
                fontsize=8, fontweight="bold", va="center", ha="right", color="#7B1FA2")

    # 구분선
    ax.axvline(x=8.5, ymin=0.02, ymax=(y_top + 0.35) / fig_h, color="#DEE2E6", linewidth=1, linestyle="--")

    plt.tight_layout()
    return fig


